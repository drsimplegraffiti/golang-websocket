### ---------------- WS Health Check ----------------
# Connect to WebSocket health check
GET ws://localhost:8082/api/health-check-ws


### Connect to WebSocket
GET ws://localhost:8082/api/ws
Authorization: Bearer <ACCESS_TOKEN>
X-Platform: web

### ---------------- SEND MESSAGE ----------------
# Send a text message in a private chat
WEBSOCKET ws://localhost:8082/api/ws
Authorization: Bearer 

{
  "event_type": "message",
  "payload": {
    "private_id": 1,
    "receiver_id": 3,
    "message_type": "text",
    "content": "Hello from REST WS!"
  }
}
END


### ---------------- MARK DELIVERED ----------------
# Mark a message as delivered
GET ws://localhost:8082/api/ws

{
  "event_type": "delivered",
  "payload": {
    "message_id": 789
  }
}


### ---------------- MARK READ ----------------
# Mark a message as read
GET ws://localhost:8082/api/ws

{
  "event_type": "read",
  "payload": {
    "message_id": 789
  }
}


### ---------------- TYPING INDICATOR ----------------
# Notify typing status
GET ws://localhost:8082/api/ws

{
  "event_type": "typing",
  "payload": {
    "private_id": 123,
    "receiver_id": 456,
    "is_typing": true
  }
}
END

